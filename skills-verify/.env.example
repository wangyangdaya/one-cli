# LangChain / LLM settings for the verifier itself.
LLM_BASE_URL=https://your-llm-endpoint.example.com/v1
# API key for the compatible OpenAI-style endpoint above.
LLM_API_KEY=replace-me
# Model name used by ChatOpenAI in skills-verify/main.py.
LLM_MODEL_NAME=gpt-4o-mini
# Python logging level for the interactive verifier process.
LOG_LEVEL=INFO
# Generated app directory used for CLI validation and loading SKILL.md files.
SKILLS_VERIFY_APP_DIR=tmp/openapi
# Base URL required by the generated openapi-cli commands.
OPENCLI_BASE_URL=https://api.example.com
