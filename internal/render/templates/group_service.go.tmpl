func Invoke{{ .CommandName | pascal }}(input {{ .CommandName | pascal }}Input) (Result, error) {
{{- if groupUsesMCPHTTP $.Group }}
	return invokeMCPHTTP("{{ .RemoteName }}", input)
{{- else if groupUsesMCPStdio $.Group }}
	return invokeMCPStdio("{{ .RemoteName }}", input)
{{- else }}
	requestURL, err := build{{ .CommandName | pascal }}URL(input)
	if err != nil {
		return Result{}, err
	}

	body, err := build{{ .CommandName | pascal }}Body(input)
	if err != nil {
		return Result{}, err
	}

	var reader io.Reader
	if len(body) > 0 {
		reader = bytes.NewReader(body)
	}

	req, err := http.NewRequest(http.Method{{ .Method | pascal }}, requestURL, reader)
	if err != nil {
		return Result{}, fmt.Errorf("build request: %w", err)
	}
	if len(body) > 0 {
		req.Header.Set("Content-Type", "application/json")
	}
{{- if operationHasHeaderParams . }}
	if err := applyHeaders(req, input.Headers); err != nil {
		return Result{}, err
	}
{{- end }}

	resp, err := httpx.NewClient().Do(req)
	if err != nil {
		return Result{}, fmt.Errorf("request {{ .Method }} {{ .Path }}: %w", err)
	}
	defer resp.Body.Close()

	payload, err := io.ReadAll(resp.Body)
	if err != nil {
		return Result{}, fmt.Errorf("read response: %w", err)
	}
	if resp.StatusCode < http.StatusOK || resp.StatusCode >= http.StatusMultipleChoices {
		return Result{}, fmt.Errorf("request failed: %s", resp.Status)
	}
	if len(bytes.TrimSpace(payload)) == 0 {
		return Result{Message: "{{ .Method }} {{ .Path }}"}, nil
	}

	var result Result
	if err := json.Unmarshal(payload, &result); err == nil && strings.TrimSpace(result.Message) != "" {
		return result, nil
	}
	return Result{Message: strings.TrimSpace(string(payload))}, nil
{{- end }}
}

