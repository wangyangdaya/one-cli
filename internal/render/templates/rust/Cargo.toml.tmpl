[package]
name = "{{ cargoPackageName .Module }}"
version = "0.1.0"
edition = "2021"

[dependencies]
clap = { version = "4", features = ["derive"] }
reqwest = { version = "0.12", features = ["json"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
tokio = { version = "1", features = ["macros", "rt-multi-thread"{{ if appHasMCPStdio .App }}, "process", "io-util"{{ end }}] }

[profile.release]
strip = true
lto = true
codegen-units = 1
panic = "abort"
