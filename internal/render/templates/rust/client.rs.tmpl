{{- if appHasMCPStdio .App }}

use tokio::io::{AsyncWriteExt, AsyncBufReadExt, BufReader};

pub async fn call_mcp_stdio_tool(
    command: &str,
    args: &[&str],
    env: &[(&str, &str)],
    tool_name: &str,
    arguments: Value,
) -> AppResult<Value> {
    use tokio::process::Command;

    trace_log!("[opencli][mcp-stdio] start\n  command: {command}\n  args: {args:?}");

    let mut child = Command::new(command)
        .args(args)
        .envs(env.iter().map(|(k, v)| (k.to_string(), v.to_string())))
        .stdin(std::process::Stdio::piped())
        .stdout(std::process::Stdio::piped())
        .stderr(std::process::Stdio::null())
        .spawn()
        .map_err(|err| format!("start MCP command: {err}"))?;

    let mut stdin = child.stdin.take().ok_or("failed to open stdin")?;
    let stdout = child.stdout.take().ok_or("failed to open stdout")?;
    let mut reader = BufReader::new(stdout);

    // initialize
    let init = json!({
        "jsonrpc": "2.0",
        "id": 1,
        "method": "initialize",
        "params": {
            "protocolVersion": "2025-03-26",
            "capabilities": {},
            "clientInfo": { "name": "opencli-rust", "version": "0.1.0" }
        }
    });
    trace_log!("[opencli][mcp-stdio] >>> initialize");
    send_stdio_message(&mut stdin, &init).await?;
    let init_resp = read_stdio_frame(&mut reader).await?;
    trace_log!("[opencli][mcp-stdio] <<< initialize\n  {}", preview(&init_resp));

    // notifications/initialized
    let notif = json!({ "jsonrpc": "2.0", "method": "notifications/initialized" });
    send_stdio_message(&mut stdin, &notif).await?;

    // tools/call
    let call = json!({
        "jsonrpc": "2.0",
        "id": 2,
        "method": "tools/call",
        "params": {
            "name": tool_name,
            "arguments": arguments
        }
    });
    trace_log!("[opencli][mcp-stdio] >>> tools/call\n  tool: {tool_name}\n  arguments: {}", preview_value(&arguments));
    send_stdio_message(&mut stdin, &call).await?;
    let response_bytes = read_stdio_frame(&mut reader).await?;
    trace_log!("[opencli][mcp-stdio] <<< tools/call\n  {}", preview(&response_bytes));

    drop(stdin);
    let _ = child.kill().await;

    let response: Value = serde_json::from_str(&response_bytes).map_err(|err| err.to_string())?;
    if let Some(err) = response.get("error") {
        let msg = err.get("message").and_then(|m| m.as_str()).unwrap_or("unknown error");
        return Err(msg.to_string());
    }
    Ok(response.get("result").cloned().unwrap_or_else(|| json!({ "message": response_bytes })))
}

async fn send_stdio_message<W: tokio::io::AsyncWrite + Unpin>(writer: &mut W, payload: &Value) -> AppResult<()> {
    let body = serde_json::to_vec(payload).map_err(|err| err.to_string())?;
    let mut msg = body;
    msg.push(b'\n');
    writer.write_all(&msg).await.map_err(|err| err.to_string())?;
    writer.flush().await.map_err(|err| err.to_string())?;
    Ok(())
}

async fn read_stdio_frame<R: tokio::io::AsyncBufRead + Unpin>(reader: &mut R) -> AppResult<String> {
    loop {
        let mut line = String::new();
        let n = reader.read_line(&mut line).await.map_err(|err| err.to_string())?;
        if n == 0 {
            return Err("unexpected EOF from MCP server".to_string());
        }
        let trimmed = line.trim();
        if trimmed.is_empty() {
            continue;
        }
        if trimmed.starts_with('{') {
            return Ok(trimmed.to_string());
        }
        // Skip non-JSON lines (Content-Length headers from LSP-style servers)
    }
}
