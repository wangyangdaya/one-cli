use clap::{Parser, Subcommand};

use crate::commands;
use crate::types::AppResult;

#[derive(Parser)]
#[command(name = "{{ .App.Name }}", about = "{{ .App.Name }} CLI")]
struct Cli {
    /// Print HTTP request and response trace logs
    #[arg(long)]
    trace: bool,

    #[command(subcommand)]
    command: GroupCommand,
}

#[derive(Subcommand)]
enum GroupCommand {
{{- range .App.Groups }}
    {{ .Name | pascal }} {
        #[command(subcommand)]
        command: commands::{{ rustModuleName . }}::Command,
    },
{{- end }}
}

pub async fn run() -> AppResult<()> {
    let cli = Cli::parse();
    crate::trace::set_enabled(cli.trace);
    match cli.command {
{{- range .App.Groups }}
        GroupCommand::{{ .Name | pascal }} { command } => command.run().await,
{{- end }}
    }
}
