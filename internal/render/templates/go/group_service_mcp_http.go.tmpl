{{- range .Group.Operations }}
type {{ .CommandName | pascal }}Input struct {
{{- range .Parameters }}
{{- if or (eq .In "path") (eq .In "query") }}
	{{ .Name | pascal }} {{ goType .Type }}
{{- end }}
{{- end }}
{{- if .BodyMode }}
	BodyData string
	BodyFile string
{{- end }}
