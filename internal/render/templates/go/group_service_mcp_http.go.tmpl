	{{ .Name | pascal }} {{ goType .Type }}
{{- end }}
}

func Invoke{{ .CommandName | pascal }}(input {{ .CommandName | pascal }}Input) (Result, error) {
	return invokeMCPHTTP("{{ .RemoteName }}", input)
}

func build{{ .CommandName | pascal }}Body(input {{ .CommandName | pascal }}Input) ([]byte, error) {
{{- if not .BodyMode }}
	return nil, nil
{{- else }}
	hasData := strings.TrimSpace(input.BodyData) != ""
	hasFile := strings.TrimSpace(input.BodyFile) != ""
	hasFlagBody := false
{{- range .BodyFields }}
{{- if eq (goType .Type) "string" }}
	hasFlagBody = hasFlagBody || strings.TrimSpace(input.{{ .Name | pascal }}) != ""
{{- else if eq (goType .Type) "int" }}
	hasFlagBody = hasFlagBody || input.{{ .Name | pascal }} != 0
{{- else if eq (goType .Type) "float64" }}
	hasFlagBody = hasFlagBody || input.{{ .Name | pascal }} != 0
{{- else if eq (goType .Type) "bool" }}
	hasFlagBody = hasFlagBody || input.{{ .Name | pascal }}
{{- end }}
{{- end }}

	switch {
	case hasData && hasFile:
		return nil, fmt.Errorf("--data and --file are mutually exclusive")
	case hasFlagBody && (hasData || hasFile):
		return nil, fmt.Errorf("body input flags cannot be combined with --data or --file")
	case hasData:
		return []byte(input.BodyData), nil
	case hasFile:
		return os.ReadFile(input.BodyFile)
{{- if eq .BodyMode "simple-json" }}
	case hasFlagBody:
{{- range .BodyFields }}
{{- if .Required }}
{{- if eq (goType .Type) "string" }}
		if strings.TrimSpace(input.{{ .Name | pascal }}) == "" {
			return nil, fmt.Errorf("missing required body field: {{ .Name }}")
		}
{{- end }}
{{- end }}
{{- end }}
		payload := map[string]any{}
{{- range .BodyFields }}
{{- if eq (goType .Type) "string" }}
		if strings.TrimSpace(input.{{ .Name | pascal }}) != "" {
			payload["{{ .Name }}"] = input.{{ .Name | pascal }}
		}
{{- else if eq (goType .Type) "int" }}
		if input.{{ .Name | pascal }} != 0 {
			payload["{{ .Name }}"] = input.{{ .Name | pascal }}
		}
{{- else if eq (goType .Type) "float64" }}
		if input.{{ .Name | pascal }} != 0 {
			payload["{{ .Name }}"] = input.{{ .Name | pascal }}
		}
{{- else if eq (goType .Type) "bool" }}
		if input.{{ .Name | pascal }} {
			payload["{{ .Name }}"] = input.{{ .Name | pascal }}
		}
{{- end }}
{{- end }}
		return json.Marshal(payload)
{{- end }}
	default:
{{- if .BodyRequired }}
		return nil, fmt.Errorf("request body is required")
{{- else }}
		return nil, nil
{{- end }}
	}
{{- end }}
}
{{ end -}}

var defaultMCPHeaders = {{ stringMapLiteral .Group.Headers }}

func invokeMCPHTTP(toolName string, input any) (Result, error) {
	requestURL := strings.TrimSpace(config.Lookup("OPENCLI_BASE_URL"))
	if requestURL == "" {
		requestURL = "{{ .Group.Endpoint }}"
	}
	if requestURL == "" {
		return Result{}, fmt.Errorf("missing OPENCLI_BASE_URL")
	}

	sessionID, err := initializeMCPHTTP(requestURL)
	if err != nil {
		return Result{}, err
	}

	arguments, err := buildMCPArguments(input)
	if err != nil {
		return Result{}, err
	}
	payload, err := json.Marshal(map[string]any{
		"jsonrpc": "2.0",
		"id":      1,
		"method":  "tools/call",
		"params": map[string]any{
			"name":      toolName,
			"arguments": arguments,
		},
	})
	if err != nil {
		return Result{}, fmt.Errorf("marshal MCP request: %w", err)
	}

	req, err := http.NewRequest(http.MethodPost, requestURL, bytes.NewReader(payload))
	if err != nil {
		return Result{}, fmt.Errorf("build MCP request: %w", err)
	}
	req.Header.Set("Content-Type", "application/json")
	req.Header.Set("Accept", "application/json, text/event-stream")
	for name, value := range defaultMCPHeaders {
		if strings.EqualFold(name, "Mcp-Session-Id") {
			continue
		}
		req.Header.Set(name, value)
	}
	if strings.TrimSpace(sessionID) != "" {
		req.Header.Set("Mcp-Session-Id", sessionID)
	}

	resp, err := http.DefaultClient.Do(req)
	if err != nil {
		return Result{}, fmt.Errorf("call MCP tool %s: %w", toolName, err)
	}
	defer resp.Body.Close()

	body, err := io.ReadAll(resp.Body)
	if err != nil {
		return Result{}, fmt.Errorf("read MCP response: %w", err)
	}
	if resp.StatusCode < http.StatusOK || resp.StatusCode >= http.StatusMultipleChoices {
		return Result{}, fmt.Errorf("mcp request failed: %s", resp.Status)
	}

	return decodeMCPResponsePayload(resp.Header.Get("Content-Type"), body)
}

func initializeMCPHTTP(requestURL string) (string, error) {
	payload, err := json.Marshal(map[string]any{
		"jsonrpc": "2.0",
		"id":      1,
		"method":  "initialize",
		"params": map[string]any{
			"protocolVersion": "2025-03-26",
			"capabilities":    map[string]any{},
			"clientInfo": map[string]any{
				"name":    "opencli",
				"version": "generated",
			},
		},
	})
	if err != nil {
		return "", fmt.Errorf("marshal MCP initialize request: %w", err)
	}

	req, err := http.NewRequest(http.MethodPost, requestURL, bytes.NewReader(payload))
	if err != nil {
		return "", fmt.Errorf("build MCP initialize request: %w", err)
	}
	req.Header.Set("Content-Type", "application/json")
	req.Header.Set("Accept", "application/json, text/event-stream")
	for name, value := range defaultMCPHeaders {
		if strings.EqualFold(name, "Mcp-Session-Id") {
			continue
		}
		req.Header.Set(name, value)
	}

	resp, err := http.DefaultClient.Do(req)
	if err != nil {
		return "", fmt.Errorf("initialize MCP tool: %w", err)
	}
	defer resp.Body.Close()

	body, err := io.ReadAll(resp.Body)
	if err != nil {
		return "", fmt.Errorf("read MCP initialize response: %w", err)
	}
	if resp.StatusCode < http.StatusOK || resp.StatusCode >= http.StatusMultipleChoices {
		return "", fmt.Errorf("mcp initialize failed: %s", resp.Status)
	}
	if _, err := decodeMCPResponsePayload(resp.Header.Get("Content-Type"), body); err != nil {
		return "", err
	}

	return resp.Header.Get("Mcp-Session-Id"), nil
}

func buildMCPArguments(input any) (map[string]any, error) {
	switch typed := input.(type) {
{{- range .Group.Operations }}
	case {{ .CommandName | pascal }}Input:
		body, err := build{{ .CommandName | pascal }}Body(typed)
		if err != nil {
			return nil, err
		}
		if len(bytes.TrimSpace(body)) == 0 {
			return map[string]any{}, nil
		}
		var arguments map[string]any
		if err := json.Unmarshal(body, &arguments); err != nil {
			return nil, fmt.Errorf("decode body arguments: %w", err)
		}
		return arguments, nil
{{- end }}
	default:
		return nil, fmt.Errorf("unsupported MCP input type %T", input)
	}
}

func decodeMCPResponsePayload(contentType string, payload []byte) (Result, error) {
	if strings.Contains(strings.ToLower(contentType), "text/event-stream") {
		var err error
		payload, err = extractSSEMessage(payload)
		if err != nil {
			return Result{}, err
		}
	}
	return decodeMCPResponse(payload)
}

func decodeMCPResponse(payload []byte) (Result, error) {
	var response struct {
		Result map[string]any `json:"result"`
		Error  *struct {
			Message string `json:"message"`
		} `json:"error"`
	}
	if err := json.Unmarshal(payload, &response); err != nil {
		return Result{}, fmt.Errorf("decode MCP response: %w", err)
	}
	if response.Error != nil {
		return Result{}, fmt.Errorf("%s", strings.TrimSpace(response.Error.Message))
	}
	if content, ok := response.Result["content"].([]any); ok {
		for _, item := range content {
			entry, ok := item.(map[string]any)
			if !ok {
				continue
			}
			if text, ok := entry["text"].(string); ok && strings.TrimSpace(text) != "" {
				return Result{Message: strings.TrimSpace(text)}, nil
			}
		}
	}
	rendered, err := json.Marshal(response.Result)
	if err != nil {
		return Result{}, err
	}
	return Result{Message: strings.TrimSpace(string(rendered))}, nil
}

// extractSSEMessage parses a text/event-stream response and extracts data: lines.
// 与 internal/mcp/transport_streamable_http.go 保持一致
func extractSSEMessage(payload []byte) ([]byte, error) {
	scanner := bufio.NewScanner(bytes.NewReader(payload))
	var dataLines []string
	for scanner.Scan() {
		line := scanner.Text()
		if strings.HasPrefix(line, "data:") {
			dataLines = append(dataLines, strings.TrimSpace(strings.TrimPrefix(line, "data:")))
		}
	}
	if err := scanner.Err(); err != nil {
		return nil, err
	}
	if len(dataLines) == 0 {
		return nil, fmt.Errorf("missing SSE data payload")
	}
	return []byte(strings.Join(dataLines, "\n")), nil
}
